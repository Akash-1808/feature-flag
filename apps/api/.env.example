# ==============================================================================
# FlagCraft API Server Environment Variables (.env.example)
# ==============================================================================
# Copy this file to .env (`cp .env.example .env`) and fill in your actual credentials.

# ------------------------------------------------------------------------------
# 1. Database Connection (PostgreSQL)
# ------------------------------------------------------------------------------
# Local Docker development connection string:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/feature_flags
# Cloud production example (e.g., Neon.tech pooled or Railway connection):
# DATABASE_URL=postgresql://neondb_owner:password@ep-example.pooler.neon.tech/neondb?sslmode=require

# ------------------------------------------------------------------------------
# 2. Redis Cache Connection (ioredis)
# ------------------------------------------------------------------------------
# Local Docker development connection string:
REDIS_URL=redis://localhost:6379
# Cloud production example (e.g., Upstash TCP rediss connection):
# REDIS_URL=rediss://default:password@your-endpoint.upstash.io:6379

# ------------------------------------------------------------------------------
# 3. Server Configuration & Authentication
# ------------------------------------------------------------------------------
# Port where the FlagCraft API server runs:
PORT=3001

# Environment mode (`development`, `test`, or `production`):
NODE_ENV=development

# Better Auth Configuration:
# Secret key used to encrypt sessions (generate with: `openssl rand -hex 32`):
BETTER_AUTH_SECRET=dev_default_secret_key_change_in_production

# Base URL where this API service is reachable:
# Local dev: http://localhost:3001 | Production: https://flagcraft-api.onrender.com
BETTER_AUTH_URL=http://localhost:3001

# ------------------------------------------------------------------------------
# 4. Optional / Production CORS & Frontend Origin Settings
# ------------------------------------------------------------------------------
# URL of your deployed Next.js Dashboard (used for CORS & Better Auth trustedOrigins):
# DASHBOARD_URL=https://flagcraft-dashboard.vercel.app
# CORS_ORIGIN=https://flagcraft-dashboard.vercel.app

# ------------------------------------------------------------------------------
# 5. Optional Rate Limiting Overrides
# ------------------------------------------------------------------------------
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=100
