# ==============================================================================
# FlagCraft Next.js Dashboard Environment Variables (.env.example)
# ==============================================================================
# Copy this file to .env.local (`cp .env.example .env.local`) when running locally.

# ------------------------------------------------------------------------------
# API Server Routing & Rewrite Configuration
# ------------------------------------------------------------------------------
# INTERNAL_API_URL specifies the target backend URL for Next.js rewrites (`/api/*` and `/sdk/*`).
# Local Docker or local dev:
INTERNAL_API_URL=http://localhost:3001
# Cloud production deployment (e.g., set on Vercel environment variables pointing to Render):
# INTERNAL_API_URL=https://flagcraft-api.onrender.com

# Public API URL used by browser clients (if different or direct):
# NEXT_PUBLIC_API_URL=http://localhost:3001
