{
    "compilerOptions": {
        "strict": true,
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "baseUrl": ".",
        "paths": {
            "@app/*": [
                "./apps/*"
            ],
            "flagcraft": [
                "./packages/sdk/dist/index.d.ts"
            ],
            "flagcraft/*": [
                "./packages/sdk/dist/*"
            ]
        }
    }
}